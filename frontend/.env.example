# Frontend Environment Variables
# Copy this file to .env.local and update with your values

# Backend API URL (default: http://127.0.0.1:8000/api)
# This is used when VITE_API_URL is not set
VITE_API_URL=http://127.0.0.1:8000/api

# Note: Vite only exposes variables prefixed with VITE_ to the client
# For development, the vite.config.ts proxy handles API routing automatically
